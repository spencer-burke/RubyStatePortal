<% content_for :title, "Manager Dashboard" %>
<% content_for :navbar, render("navbar") %>
<% content_for :controllers, "manager-dashboard" %>

<h1>Manager Dashboard</h1>
<p>Welcome to the Manager Dashboard</p>

<button
    id="open_property_create_modal"
    data-action="click->manager-dashboard#showPropertyModal"
>
Create Property
</button>

<%= turbo_frame_tag "properties_list", src: properties_path do %>
    <p>Loading properties...</p>
<% end %>

<%= turbo_frame_tag "modal" %>

<dialog id="property_create_modal" data-manager-dashboard-target="dialog">
    <article>
        <header>
          <button aria-label="Close" rel="prev" data-action="click->manager-dashboard#closePropertyModal"></button>
          <p><strong>Create New Property</strong></p>
        </header>

        <fieldset>
          <%= button_to "Create Single Unit",
                      new_property_path,
                      params: { type: "SingleUnitProperty"},
                      data: { turbo_frame: "modal", action: "click->manager-dashboard#closePropertyModal" },
                      class: "outline",
                      method: :get,
                      role: "button" %>

          <%= button_to "Create Multi Unit",
                    new_property_path,
                    params: { type: "MultiUnitProperty" },
                    data: { turbo_frame: "modal", action: "click->manager-dashboard#closePropertyModal"},
                    class: "outline",
                    method: :get,
                    role: "button" %>
        </fieldset>

        <footer>
          <button class="secondary" data-action="click->manager-dashboard#closePropertyModal">
            Cancel
          </button>
        </footer>
      </article>
</dialog>
