<%= turbo_frame_tag dom_id(single_unit_property) do %>
    <article class="property-card single-unit">
        <h3><%= single_unit_property.name %> (Single Unit)</h3>
        <p><%= single_unit_property.address %>, <%= single_unit_property.address_extension %></p>
        <p><%= single_unit_property.city %>, <%= single_unit_property.state %></p>
        <%= button_to "Edit", edit_property_path(single_unit_property), method: :get, data: { turbo_frame: "modal" }, class: "button" %>
    </article>
<% end %>
